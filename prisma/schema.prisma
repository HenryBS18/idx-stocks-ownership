generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  username String @id
  password String
}

model Stock {
  ticker String @id
  name   String

  stockInvestor StockInvestor[]
}

model StockInvestor {
  id                String @id @default(nanoid())
  ticker            String
  investorName      String
  investorType      String
  localForeign      String
  domicile          String
  scripless         Int
  scrip             Int
  totalHoldingShare Int
  percentage        Float
  stock             Stock  @relation(fields: [ticker], references: [ticker])
}
